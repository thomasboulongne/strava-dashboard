# Strava API credentials
# Get these from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# Site URL (used for OAuth redirect)
# Use http://localhost:8888 for local development with netlify dev
# Use your Netlify URL for production
SITE_URL=http://localhost:8888

# MCP server (ChatGPT connector) - exposes your stored Strava data read-only at /mcp
# Each user generates a personal key in the dashboard (Settings page); the key
# maps to their athlete and is carried in the connector URL (/mcp?key=...).
# No env var is required in production.
#
# MCP_ATHLETE_ID is a LOCAL-DEV convenience only: when set, requests to /mcp
# without a key fall back to this athlete. Leave empty in production.
MCP_ATHLETE_ID=

